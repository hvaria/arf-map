# ── Application ────────────────────────────────────────────────────────────────
# Node environment. Set to "production" on your server.
NODE_ENV=development

# Express listen port (Render / Railway / Fly.io set this automatically).
PORT=5000

# ── Session security ────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
# REQUIRED in production — the default value is insecure.
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# ── Database ────────────────────────────────────────────────────────────────────
# Absolute or relative path to the directory where data.db is stored.
# In Docker / Render, point this to a persistent disk mount (e.g. /data).
# Omit to store data.db in the project root (fine for local development).
# DATA_DIR=/data

# ── Email (SMTP) ────────────────────────────────────────────────────────────────
# Used for OTP email verification on registration.
# Leave blank in development — OTPs will be logged to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=ARF Care Portal <your-email@gmail.com>

# ── Mobile / PWA (optional) ─────────────────────────────────────────────────────
# Set to the server's public URL when building Capacitor native apps.
# Leave blank for standard web deployments.
# VITE_API_URL=https://your-domain.com
